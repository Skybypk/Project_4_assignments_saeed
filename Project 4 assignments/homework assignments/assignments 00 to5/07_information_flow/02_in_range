#Solution
def in_range(n, low, high):
    """
    Returns True if n is between low and high, inclusive. 
    high is guaranteed to be greater than low.
    """
    if n >= low and n <= high:
        return True  # Indented correctly to align with the 'if' statement

    return False  # Indented correctly for the return outside of the 'if'

# Example to test the function
def main():
    # Testing the function
    print(in_range(5, 1, 10))  # True: 5 is between 1 and 10
    print(in_range(0, 1, 10))  # False: 0 is not between 1 and 10
    print(in_range(10, 1, 10)) # True: 10 is between 1 and 10, inclusive

# This provided line is required at the end of the Python file to call the main() function.
if __name__ == '__main__':
    main()
