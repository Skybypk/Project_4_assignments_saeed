#Solution
def main():
    # Loop through numbers from 0 to 9
    for i in range(10):
        if is_odd(i):
            print('odd')
        else:
            print('even')
            
def is_odd(value: int):
    """
    Checks to see if a value is odd. If it is, returns True.
    """
    # If the remainder when divided by 2 is 1, it's odd
    remainder = value % 2
    return remainder == 1

